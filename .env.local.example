# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email — Resend (https://resend.com/api-keys)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Newsletter — used to protect the /api/newsletter/send endpoint
NEWSLETTER_API_KEY="your-secret-key-here"

# Public app URL (used for unsubscribe links)
NEXT_PUBLIC_APP_URL="https://thefearless.xyz"

# Payments — Razorpay
RAZORPAY_KEY_ID="rzp_live_xxxx"
RAZORPAY_KEY_SECRET="xxxx"
RAZORPAY_WEBHOOK_SECRET="xxxx"

# AI providers
ANTHROPIC_API_KEY="sk-ant-xxxx"
GEMINI_API_KEY="AIzaSy-xxxx"
GROQ_API_KEY="gsk_xxxx"

# Rate limiting — Upstash Redis
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"
